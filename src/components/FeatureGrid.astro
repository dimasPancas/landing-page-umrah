---
// Feature Grid showcasing 4 main advantages
const features = [
  {
    icon: 'shield',
    title: 'Berizin Resmi',
    description: 'Terdaftar dan diawasi langsung oleh Kementerian Agama RI serta PIHK.',
  },
  {
    icon: 'users',
    title: 'Pembimbing Ahli',
    description: 'Didampingi mutawif dan ustadz bersertifikat internasional yang berpengalaman.',
  },
  {
    icon: 'dollar',
    title: 'Harga Transparan',
    description: 'Biaya jelas tanpa biaya tersembunyi. Cicilan ringan tanpa bunga tersedia.',
  },
  {
    icon: 'phone',
    title: 'Support 24 Jam',
    description: 'Tim customer service siap membantu Anda kapanpun selama perjalanan.',
  },
];
---

<section id="keunggulan" class="py-20 md:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="text-emerald-600 font-semibold text-sm tracking-widest uppercase">Kenapa Kami</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-gray-900 mt-3 mb-4">
        Keunggulan <span class="text-emerald-600">Al-Qibla</span>
      </h2>
      <p class="text-gray-500 max-w-xl mx-auto text-base">
        Kami berkomitmen memberikan pelayanan terbaik untuk ibadah yang lebih khusyuk dan nyaman.
      </p>
    </div>

    <!-- Feature Cards Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        features.map((feature) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 transition hover:shadow-xl hover:-translate-y-1 duration-300 text-center">
            <div class="w-14 h-14 bg-emerald-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
              {feature.icon === 'shield' && (
                <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  />
                </svg>
              )}
              {feature.icon === 'users' && (
                <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                  />
                </svg>
              )}
              {feature.icon === 'dollar' && (
                <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
              )}
              {feature.icon === 'phone' && (
                <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  />
                </svg>
              )}
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{feature.title}</h3>
            <p class="text-sm text-gray-500">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
