---
// Footer with company info, navigation, and contact details
---

<footer class="bg-gray-900 text-gray-400 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 text-white text-xl font-bold mb-4">
          <svg class="w-6 h-6 text-emerald-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
          </svg>
          Al-Qibla Travel
        </div>
        <p class="text-sm leading-relaxed">
          Mitra perjalanan ibadah Haji & Umrah Anda. Berizin resmi Kemenag RI, berpengalaman sejak 2015.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Navigasi</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#hero" class="hover:text-emerald-400 transition">Beranda</a></li>
          <li><a href="#paket" class="hover:text-emerald-400 transition">Paket Umrah</a></li>
          <li><a href="#keunggulan" class="hover:text-emerald-400 transition">Keunggulan</a></li>
          <li><a href="#testimoni" class="hover:text-emerald-400 transition">Testimoni</a></li>
          <li><a href="#kontak" class="hover:text-emerald-400 transition">Kontak</a></li>
        </ul>
      </div>

      <!-- Paket -->
      <div>
        <h4 class="text-white font-semibold mb-4">Paket</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#paket" class="hover:text-emerald-400 transition">Paket Izzah – Rp25Jt</a></li>
          <li><a href="#paket" class="hover:text-emerald-400 transition">Paket Mabrur – Rp35Jt</a></li>
          <li><a href="#paket" class="hover:text-emerald-400 transition">Paket Multazam – Rp55Jt</a></li>
          <li><a href="#paket" class="hover:text-emerald-400 transition">Paket Haji Khusus</a></li>
        </ul>
      </div>

      <!-- Kontak -->
      <div>
        <h4 class="text-white font-semibold mb-4">Kontak</h4>
        <ul class="space-y-2 text-sm">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            +62 812-3456-7890
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            info@alqiblatravel.com
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Jl. Merdeka No. 123, Jakarta Pusat
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-8 flex flex-col sm:flex-row items-center justify-between text-sm">
      <p>&copy; 2025 Al-Qibla Travel Umrah & Haji. All rights reserved.</p>
      <div class="flex items-center gap-4 mt-4 sm:mt-0">
        <span class="text-emerald-400">⭐ 4.9</span>
        <span class="text-gray-500">|</span>
        <span>1.250+ jamaah</span>
      </div>
    </div>
  </div>
</footer>
